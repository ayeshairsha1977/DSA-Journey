class Solution(object):
    def isPerfectSquare(self, num):
        low,end=0,num
        while low<=end:
            mid=low+(end-low)//2
            if mid*mid==num:
                return True
            elif mid*mid > num: 
                end=mid-1
            else:
                low=mid+1
        return False
        """
        :type num: int
        :rtype: bool
        """
        