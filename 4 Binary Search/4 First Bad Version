# The isBadVersion API is already defined for you.
# @param version, an integer
# @return a bool
# def isBadVersion(version):

class Solution(object):
    def firstBadVersion(self, n):
        low,end=1,n
        while low<=end:
            mid=low+(end-low)//2
            if isBadVersion(mid):
                end=mid-1
            else:
                low=mid+1
        return low
        