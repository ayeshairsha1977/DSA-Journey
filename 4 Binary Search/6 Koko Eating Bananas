class Solution(object):
    def minEatingSpeed(self, piles, h):
        low,high,ans=1,max(piles),float('inf')
        while low<=high:
            mid=low+(high-low)//2
            hours=sum(math.ceil(float(i)/mid) for i in piles)
            if hours<=h:
                ans=mid
                high=mid-1
            elif hours > h:
                low=mid+1
        return ans