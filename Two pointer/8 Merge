class Solution(object):
    def merge(self, nums1, m, nums2, n):
        i,j,k=m-1,n-1,len(nums1)-1
        while j>=0 and i>=0:
            if nums2[j]>nums1[i]:
                nums1[k]=nums2[j]
                j-=1
            else:
                nums1[k]=nums1[i]
                i-=1
            k-=1
        if j!=-1:
            while j>=0:
                nums1[k]=nums2[j]
                j-=1
                k-=1