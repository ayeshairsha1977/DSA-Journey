class Solution(object):
    def maxArea(self, height):
        maxi=float('-inf')
        count=len(height)-1
        i,j=0,count
        while i<j:
            if height[i]<height[j]:
                min=height[i]
                i+=1
            else:
                min=height[j]
                j-=1
            maxi=max(maxi,min*count)
            count-=1
        return maxi