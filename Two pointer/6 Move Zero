class Solution(object):
    def moveZeroes(self, nums):
        i=0
        while(i<len(nums) and nums[i]!=0):
            i+=1
        k=i+1
        while(k<len(nums)):
            while(k<len(nums) and nums[k]==0 ):
                k+=1
            if k==len(nums):
                break
            nums[i],nums[k]=nums[k],nums[i]
            i+=1
             
            
        