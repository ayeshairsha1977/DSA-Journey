class Solution(object):
    def equalSubstring(self, s, t, maxCost):
        sumi,maxi,start=0,0,0
        for end in range(len(s)):
            sumi+=abs(ord(s[end])-ord(t[end]))
            while sumi>maxCost:
                sumi-=abs(ord(s[start])-ord(t[start]))
                start+=1
            maxi=max(maxi,end-start+1)
            
        return maxi