class Solution(object):
    def minSubArrayLen(self, target, nums):
        start=0
        end=0
        sumi=0
        maxi=float('inf')
        while end<len(nums):
            sumi+=nums[end]
            while sumi>=target:
                maxi=min(maxi,end-start+1)
                sumi-=nums[start]
                start+=1
            end+=1
        return 0 if maxi==float('inf') else maxi
            