class Solution(object):
    def maxSlidingWindow(self, nums, k):
        d=deque()
        res=[]
        for i in range(len(nums)):
            while d and d[0]<i-k+1:
                d.popleft()
            while d and nums[d[-1]]<nums[i]:
                d.pop()
            d.append(i)

            if i>k-2:
                res.append(nums[d[0]])
        return res