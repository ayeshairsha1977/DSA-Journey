class Solution(object):
    def numOfSubarrays(self, arr, k, threshold):
        con=0
        sum=0
        threshold*=k
        for i in range(k):
            sum+=arr[i]
        if sum>=threshold:
            con+=1
        for i in range(k,len(arr)):
            sum+=arr[i]-arr[i-k]
            if sum>=threshold:
                con+=1
        return con