class Solution(object):
    def numRescueBoats(self, people, limit):
        s,e=0,len(people)-1
        people.sort()
        mini=0
        while s<=e:
            if s!=e:
                add=people[s]+people[e]
            else:
                add=people[s]
            if add>limit:
                mini+=1
                e-=1
            else:
                mini+=1
                s+=1
                e-=1
        return mini