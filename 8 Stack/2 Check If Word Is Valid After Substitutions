class Solution(object):
    def isValid(self, s):
        stack=[]
        for i in s:
            stack.append(i)
            if len(stack)>2 and "".join(stack[-3:])=="abc":
                    # stack.pop()
                    # stack.pop()
                    # stack.pop()
                    del stack[-3:]
        return True if len(stack)==0 else False
        